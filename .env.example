# Copy to .env and fill in. Never commit the real .env.

# Long random string — generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Postgres password (must match POSTGRES_PASSWORD below)
POSTGRES_PASSWORD=

# Payload connects to the compose `postgres` service over the internal network.
# Host is the service name `postgres`, not localhost.
DATABASE_URI=postgres://lesson3:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/lesson3

NODE_ENV=production
PORT=3000
