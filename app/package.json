{
  "name": "app",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "typecheck": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next typegen && tsc --noEmit -p tsconfig.json",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=moderate",
    "test": "npm run test:int && npm run test:e2e",
    "test:rock": "npm run test:unit && npm run test:int && npm run test:http",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:http": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.http.config.mts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:unit": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.unit.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/email-nodemailer": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "acorn": "8.16.0",
    "cross-env": "7.0.3",
    "docx": "9.6.1",
    "dompurify": "3.4.11",
    "dotenv": "16.4.7",
    "drizzle-orm": "0.45.2",
    "graphql": "16.14.1",
    "jszip": "3.10.1",
    "mammoth": "1.12.0",
    "next": "16.2.6",
    "payload": "3.85.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.2"
  },
  "overrides": {
    "undici": "7.28.0",
    "postcss": "8.5.16",
    "nodemailer": "9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/jsdom": "28.0.3",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "28.0.0",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "volta": {
    "node": "22.17.0"
  }
}
