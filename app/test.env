NODE_OPTIONS="--no-deprecation --no-experimental-strip-types"

# Integration-test environment. `.env` points DATABASE_URI at the Docker service
# host `postgres`, which is unresolvable on a dev host; vitest.setup.ts loads this
# file with override so `npm run test:int` targets a local test database.
# Requires a Postgres reachable at this URI (e.g. a local container) to actually run.
DATABASE_URI=postgres://lesson3:lesson3@localhost:5432/lesson3_test
PAYLOAD_SECRET=test-secret-not-for-production
