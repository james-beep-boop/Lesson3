# Database (Postgres). In Docker this points at the compose service host `postgres`.
DATABASE_URI=postgres://lesson3:CHANGE_ME@postgres:5432/lesson3
# Used by the postgres service in docker-compose.yml (must match DATABASE_URI password).
POSTGRES_PASSWORD=CHANGE_ME

# Payload secret — long random string; rotating it invalidates existing sessions.
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Base URL used to build links in emails (e.g. the password-reset link). No trailing slash.
ADMIN_URL=http://localhost:3001

# Optional. Setting SERVER_URL makes Payload enforce a strict CSRF allowlist for
# cookie auth, which BOUNCES browsers that don't send `Sec-Fetch-Site` on same-origin
# GETs (e.g. older Safari over plain HTTP) — they log in then loop back. Leave it EMPTY
# on internal/plain-HTTP hosts (cookie auth still uses a SameSite=Lax cookie). A public
# HTTPS host may set it to opt into strict CSRF. Must be empty, not unset-to-undefined.
SERVER_URL=

# DOCX -> PDF conversion sidecar (Gotenberg). In Docker this points at the compose
# service host `gotenberg`. Leave as-is for the standard compose stack; override only if
# you run the converter elsewhere. PDF export (?as=pdf) fails fast if this is unreachable.
GOTENBERG_URL=http://gotenberg:3000
# Optional. Per-conversion request timeout (ms); caps a hung conversion. Default 120000,
# matching the sidecar's --api-timeout in docker-compose.yml.
GOTENBERG_TIMEOUT_MS=120000
# Optional. Max CONCURRENT synchronous conversions for the editor's unsaved "View as PDF"
# (POST /:id/preview-pdf), which runs Gotenberg inside the request. Excess requests get 503.
# In-process (per app instance); default 2, matching the jobs-queue global cap. See lib/conversionLimit.ts.
PREVIEW_PDF_MAX_CONCURRENT=2

# Artifact cache (generated DOCX/PDF bytes). Generation is content-stable, so a hit by
# (bundle, version, document, format, kind) skips both the generator and Gotenberg. In the
# compose stack this is the path of the `lesson3_artifact_cache` named volume on the `app`
# service (durable across `up --build`); unset falls back to a local ./.artifact-cache for dev.
ARTIFACT_CACHE_DIR=/var/cache/lesson3
# Optional. Evicts oldest-by-mtime once total cache size exceeds this. Default 512 MiB.
ARTIFACT_CACHE_MAX_BYTES=536870912

# Optional per-user rate limits on the expensive generation endpoints (readiness #1).
# Defaults shown; tune for your user base. Window is a FIXED window in ms (a shared Postgres
# counter — see lib/rateLimit.ts; up to ~2x the budget can slip across one window boundary).
RATE_LIMIT_EXPORT_MAX=20
RATE_LIMIT_EXPORT_WINDOW_MS=60000
RATE_LIMIT_PREVIEW_MAX=40
RATE_LIMIT_PREVIEW_WINDOW_MS=60000
# Editor "View as PDF" of an UNSAVED working copy (POST /:id/preview-pdf) — tighter than export/preview
# because it runs Gotenberg synchronously in the request (concurrency is bounded separately by
# PREVIEW_PDF_MAX_CONCURRENT above). Default 10 per minute.
RATE_LIMIT_PREVIEW_PDF_MAX=10
RATE_LIMIT_PREVIEW_PDF_WINDOW_MS=60000
# Email-a-doc (SPEC §10): a strict per-user DAILY cap on outbound sends (default 10 per 24h),
# because the bounded cost is other people's inboxes + SMTP reputation, not our CPU.
RATE_LIMIT_EMAIL_MAX=10
RATE_LIMIT_EMAIL_WINDOW_MS=86400000
# Abuse controls above the per-user cap: how much mail ONE recipient address may get from us per
# day (shared across senders), and the site-wide daily ceiling on outbound sends.
RATE_LIMIT_EMAIL_RECIPIENT_MAX=20
RATE_LIMIT_EMAIL_RECIPIENT_WINDOW_MS=86400000
RATE_LIMIT_EMAIL_GLOBAL_MAX=1000
RATE_LIMIT_EMAIL_GLOBAL_WINDOW_MS=86400000
# Internal messaging (SPEC §10): per-user DAILY cap on message creation, and a per-recipient
# daily cap on the content-free notification-ping EMAILS (exhaustion skips the ping, never the
# message; pings are also gated to fire only when the recipient had zero unread).
RATE_LIMIT_MESSAGE_MAX=50
RATE_LIMIT_MESSAGE_WINDOW_MS=86400000
RATE_LIMIT_MESSAGE_PING_RECIPIENT_MAX=20
RATE_LIMIT_MESSAGE_PING_RECIPIENT_WINDOW_MS=86400000

# Email (optional). If SMTP_HOST is unset, mail falls back to the console and password
# resets are NOT delivered. To enable real email (e.g. password resets), set all of these.
# Gmail: host=smtp.gmail.com, port=465, user=<account>, pass=<16-char Google App Password>
# (App Passwords require 2-Step Verification; your normal Google login will NOT work.)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=ARES Lesson Library
EMAIL_FROM_ADDRESS=
